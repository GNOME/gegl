msgstr ""
"Математикалық алу операциясы, 'value' ішінде берілген тұрақты мәнді немесе "
"aux буферіндегі сәйкес пиксельді операнд ретінде пайдаланып, операцияны әр "
"пиксель үшін орындайды. Нәтиже — result = input - value өрнегін есептеу"

#: operations/generated/xor.c:155
msgid "Porter Duff operation xor (d = cA * (1.0f - aB)+ cB * (1.0f - aA))"
msgstr "Porter Duff xor операциясы (d = cA * (1.0f - aB)+ cB * (1.0f - aA))"

