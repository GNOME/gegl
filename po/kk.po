msgstr "Porter Duff dst-in операциясы (d = cB * aA)"

#: operations/generated/dst-out.c:155
msgid "Porter Duff operation dst-out (d = cB * (1.0f - aA))"
msgstr "Porter Duff dst-out операциясы (d = cB * (1.0f - aA))"

