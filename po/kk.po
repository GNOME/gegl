#: operations/generated/add.c:137
msgid ""
"Math operation add, performs the operation per pixel, using either the "
"constant provided in 'value' or the corresponding pixel from the buffer on "
"aux as operands. The result is the evaluation of the expression result = "
"input + value"
msgstr ""
"Математикалық қосу операциясы, 'value' ішінде берілген тұрақты мәнді немесе "
"aux буферіндегі сәйкес пиксельді операнд ретінде пайдаланып, операцияны әр "
"пиксель үшін орындайды. Нәтиже — result = input + value өрнегін есептеу"

#: operations/generated/clear.c:133
msgid "Porter Duff operation clear (d = 0.0f)"
msgstr "Porter Duff тазарту операциясы (d = 0.0f)"

#: operations/generated/color-burn.c:188
msgid ""
"SVG blend operation color-burn (<code>if cA * aB + cB * aA <= aA * aB: d = "
"cA * (1 - aB) + cB * (1 - aA) otherwise: d = (cA == 0 ? 1 : (aA * (cA * aB "
"+ cB * aA - aA * aB) / cA) + cA * (1 - aB) + cB * (1 - aA))</code>)"
msgstr ""
"SVG араластыру операциясы түсті күйдіру (<code>if cA * aB + cB * aA <= aA * "
"aB: d = cA * (1 - aB) + cB * (1 - aA) otherwise: d = (cA == 0 ? 1 : (aA * "
"(cA * aB + cB * aA - aA * aB) / cA) + cA * (1 - aB) + cB * (1 - aA))</code>)"

#: operations/generated/color-dodge.c:188
msgid ""
"SVG blend operation color-dodge (<code>if cA * aB + cB * aA >= aA * aB: d = "
"aA * aB + cA * (1 - aB) + cB * (1 - aA) otherwise: d = (cA == aA ? 1 : cB * "
"aA / (aA == 0 ? 1 : 1 - cA / aA)) + cA * (1 - aB) + cB * (1 - aA)</code>)"
msgstr ""
"SVG араластыру операциясы color-dodge (<code>if cA * aB + cB * aA >= aA * "
"aB: d = aA * aB + cA * (1 - aB) + cB * (1 - aA) otherwise: d = (cA == aA ? "
"1 : cB * aA / (aA == 0 ? 1 : 1 - cA / aA)) + cA * (1 - aB) + cB * (1 - aA)</"
"code>)"

#: operations/generated/darken.c:184
msgid ""
"SVG blend operation darken (<code>d = MIN (cA * aB, cB * aA) + cA * (1 - "
"aB) + cB * (1 - aA)</code>)"
msgstr ""
"SVG араластыру операциясы қараңғылату (<code>d = MIN (cA * aB, cB * aA) + "
"cA * (1 - aB) + cB * (1 - aA)</code>)"

#: operations/generated/difference.c:184
msgid ""
"SVG blend operation difference (<code>d = cA + cB - 2 * (MIN (cA * aB, cB * "
"aA))</code>)"
msgstr ""
"SVG араластыру операциясы айырмашылық (<code>d = cA + cB - 2 * (MIN (cA * "
"aB, cB * aA))</code>)"

#: operations/generated/divide.c:137
msgid ""
"Math operation divide, performs the operation per pixel, using either the "
"constant provided in 'value' or the corresponding pixel from the buffer on "
"aux as operands. The result is the evaluation of the expression result = "
"value==0.0f?0.0f:input/value"
msgstr ""
"Математикалық бөлу операциясы, 'value' ішінде берілген тұрақты мәнді немесе "
"aux буферіндегі сәйкес пиксельді операнд ретінде пайдаланып, операцияны әр "
"пиксель үшін орындайды. Нәтиже — result = value==0.0f?0.0f:input/value "
"өрнегін есептеу"

#: operations/generated/dst-atop.c:133
msgid "Porter Duff operation dst-atop (d = cB * aA + cA * (1.0f - aB))"
